@model web.Models.ViewModels.StudyPostDetailsVM

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        ← Back to study posts
    </a>
</div>

@if (TempData["ToastMessage"] != null)
{
    <div class="alert alert-success mb-3">@TempData["ToastMessage"]</div>
}

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm session-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <span class="badge bg-light text-secondary mb-2">
                            @Model.SubjectName
                        </span>

                        <h2 class="mb-2">@Model.Title</h2>

                        <p class="text-muted mb-0">
                            Organized by @Model.OrganizerName
                        </p>
                    </div>

                    @if (Model.IsOnline)
                    {
                        <span class="session-type-badge session-type-online">Online</span>
                    }
                    else
                    {
                        <span class="session-type-badge session-type-physical">On campus</span>
                    }
                </div>

                <hr />

                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-6">
                        <div class="p-3 rounded border">
                            <div class="text-muted small mb-1">Date and time</div>
                            <strong>@Model.StartAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="p-3 rounded border">
                            <div class="text-muted small mb-1">Location</div>
                            <strong>@Model.Location</strong>
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="p-3 rounded border">
                            <div class="text-muted small mb-1">Participants</div>
                            <strong>@Model.ParticipantsCount / @Model.MaxParticipants</strong>

                            @if (Model.IsFull)
                            {
                                <span class="badge bg-danger ms-2">Full</span>
                            }
                            else
                            {
                                <span class="badge bg-success ms-2">Open</span>
                            }
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="p-3 rounded border">
                            <div class="text-muted small mb-1">Created at</div>
                            <strong>@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    @if (Model.IsOwner)
                    {
                        <a asp-action="Participants" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            Manage participants
                        </a>
                    }

                    @if (Model.IsJoined)
                    {
                        <form asp-action="Leave" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger">
                                Leave session
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Join" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary" @(Model.IsFull ? "disabled" : "")>
                                Join session
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm session-card">
            <div class="card-body">
                <h5 class="mb-3">
                    Participants
                    <span class="text-muted small">(@Model.ParticipantsCount)</span>
                </h5>

                @if (!Model.Participants.Any())
                {
                    <p class="text-muted mb-0">No participants yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var p in Model.Participants)
                        {
                            var displayName = !string.IsNullOrWhiteSpace(p.Name) ? p.Name : p.Email;
                            var initials = string.Join("", displayName
                                .Split(" ", StringSplitOptions.RemoveEmptyEntries)
                                .Take(2)
                                .Select(x => x[0]))
                                .ToUpper();

                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center"
                                     style="width: 40px; height: 40px;">
                                    @initials
                                </div>

                                <div>
                                    <div class="fw-semibold">@displayName</div>
                                    <div class="text-muted small">
                                        Joined @p.JoinedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>