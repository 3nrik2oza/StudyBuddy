@model List<web.Controllers.NotificationGroupVM>

@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Notifications</h2>
        <p class="text-muted mb-0">
            Recent tutoring messages and request updates.
        </p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm session-card">
        <div class="card-body text-center py-5">
            <div class="display-6 mb-3">🔔</div>
            <h4 class="mb-2">No notifications yet</h4>
            <p class="text-muted mb-0">
                New tutoring messages and request updates will appear here.
            </p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var n in Model)
        {
            <div class="card border-0 shadow-sm session-card">
                <div class="card-body d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <h5 class="mb-0">@n.Title</h5>

                            @if (n.Count > 0)
                            {
                                <span class="badge bg-danger rounded-pill">
                                    @n.Count new
                                </span>
                            }
                        </div>

                        <p class="text-muted mb-2">
                            @n.LastMessage
                        </p>

                        <small class="text-muted">
                            @n.LastCreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </small>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(n.Link))
                    {
                        <a href="@n.Link" class="btn btn-outline-primary btn-sm">
                            Open
                        </a>
                    }
                </div>
            </div>
        }
    </div>
}